#!/bin/sh /etc/rc.common
# chimera-rawmodem: standalone APRS digipeater (requires chimera-bridge)
# Install: copy to /etc/init.d/chimera-digipeater, chmod +x, enable.
# The daemon exits immediately if digipeater.enabled is false in config.

START=95
USE_PROCD=1

PROG=/usr/bin/chimera-digipeater.py
CONF=/etc/chimera/config.yaml

start_service() {
	procd_open_instance
	procd_set_param command /usr/bin/python "$PROG" "$CONF"
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
