#!/bin/sh /etc/rc.common
# chimera-rawmodem: APRS-IS iGate (requires chimera-bridge + internet)
# Install: copy to /etc/init.d/chimera-igate, chmod +x, enable.
# The daemon exits immediately if igate.enabled is false in config —
# the iGate is independently toggleable without touching the digipeater.

START=95
USE_PROCD=1

PROG=/usr/bin/chimera-igate.py
CONF=/etc/chimera/config.yaml
CREDS=/etc/chimera/aprs-is.conf

start_service() {
	procd_open_instance
	procd_set_param command /usr/bin/python "$PROG" "$CONF" "$CREDS"
	procd_set_param respawn 3600 10 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
